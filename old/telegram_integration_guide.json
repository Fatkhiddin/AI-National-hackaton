    "2_API_ENDPOINTS": {
      "base_api_url": "/api",
      "authentication": {
        "method": "JWT Bearer Token",
        "login_endpoint": "/api/login/",
        "register_endpoint": "/api/register/",
        "token_refresh": "/api/token/refresh/",
        "description": "Login qilib JWT token olish kerak"
      },
      "main_search_endpoint": {
        "url": "/api/objects/",
        "method": "GET",
        "description": "Obyektlarni qidirish va filtrlash",
        "filter_backend": "DjangoFilterBackend + SearchFilter",
        "supports": [
          "Query parameters filtering",
          "Full text search",
          "Range filters (min/max)",
          "Multiple value filters (ManyToMany)"
        ]
      },
      "detail_endpoint": {
        "url": "/api/objects/{id}/",
        "method": "GET",
        "description": "Bitta obyektning batafsil ma'lumoti"
      },
      "reference_endpoints": {
        "description": "Filtrlash uchun reference data",
        "endpoints": [
          "/api/Categorys/ - Kategoriyalar",
          "/api/SubCategorys/ - Sub kategoriyalar",
          "/api/SaleTypes/ - Sotuv turlari",
          "/api/Rents/ - Ijara turlari",
          "/api/StateRepairs/ - Ta'mir holati",
          "/api/Furnitures/ - Mebel",
          "/api/PropertyTypes/ - Mulk turlari",
          "/api/TypeBuildings/ - Bino turlari",
          "/api/addresses/ - Manzillar"
        ]
      }
    },

