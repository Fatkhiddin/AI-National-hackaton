    "8_EXAMPLE_PYTHON_CODE": {
      "description": "Telegram bot uchun Python kod namunasi",
      "code": "import requests\n\nclass MegapolisCRM:\n    def __init__(self, base_url, username, password):\n        self.base_url = base_url\n        self.token = self.login(username, password)\n    \n    def login(self, username, password):\n        url = f'{self.base_url}/api/login/'\n        response = requests.post(url, json={'username': username, 'password': password})\n        return response.json()['access']\n    \n    def search_properties(self, filters):\n        url = f'{self.base_url}/api/objects/'\n        headers = {'Authorization': f'Bearer {self.token}'}\n        \n        # AI dan kelgan filterlarni CRM formatiga o'girish\n        params = self.map_filters(filters)\n        \n        response = requests.get(url, headers=headers, params=params)\n        return response.json()\n    \n    def map_filters(self, ai_filters):\n        params = {}\n        \n        if 'rooms' in ai_filters:\n            params['rooms_numbers'] = ai_filters['rooms']\n        \n        if 'price_min' in ai_filters:\n            params['min_price'] = ai_filters['price_min']\n        \n        if 'price_max' in ai_filters:\n            params['max_price'] = ai_filters['price_max']\n        \n        if 'area_min' in ai_filters:\n            params['min_area'] = ai_filters['area_min']\n        \n        if 'area_max' in ai_filters:\n            params['max_area'] = ai_filters['area_max']\n        \n        if 'location' in ai_filters:\n            params['search'] = ai_filters['location']\n        \n        if 'category_id' in ai_filters:\n            params['category'] = ai_filters['category_id']\n        \n        return params\n    \n    def format_for_telegram(self, property_data):\n        message = f\"🏠 {property_data['name']}\\n\\n\"\n        message += f\"💰 Narx: ${property_data['price_starting']} {property_data['price_type']}\\n\"\n        message += f\"📐 Maydon: {property_data['total_area']} m²\\n\"\n        message += f\"🚪 Xonalar: {property_data['rooms_numbers']}\\n\"\n        message += f\"🏢 Qavat: {property_data['floor']}/{property_data['floor_build']}\\n\"\n        message += f\"📍 {property_data['address']['full_address']}\\n\"\n        return message\n\n# Ishlatish\ncrm = MegapolisCRM('https://megapolis1.uz', 'bot_user', 'bot_password')\nresults = crm.search_properties({'rooms': 3, 'price_min': 50000, 'price_max': 80000})\n\nfor prop in results['results']:\n    message = crm.format_for_telegram(prop)\n    # Send to Telegram..."
    }
  }
